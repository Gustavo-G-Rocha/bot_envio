{
  "appId": "com.botenvio.app",
  "productName": "Bot Envio WhatsApp",
  "directories": {
    "buildResources": ".",
    "output": "dist"
  },
  "compression": "normal",
  "asar": false,
  "files": [
    ".chromium-cache/**/*",
    "**/*",
    "!node_modules/.cache",
    "!**/{.git,.hg,.svn,CVS,RCS,SCCS}",
    "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp}"
  ],
  "asarUnpack": [
    "node_modules/puppeteer/**/*",
    "node_modules/whatsapp-web.js/**/*",
    ".chromium-cache/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Bot Envio WhatsApp",
    "deleteAppDataOnUninstall": true,
    "perMachine": true,
    "allowElevation": true,
    "include": "installer.nsh"
  }
}
